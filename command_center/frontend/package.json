{
  "name": "command-center-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "api:gen": "openapi-typescript ../backend/openapi.json -o src/lib/api/schema.d.ts",
    "api:check": "openapi-typescript ../backend/openapi.json -o /tmp/cc-schema.d.ts && diff /tmp/cc-schema.d.ts src/lib/api/schema.d.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.0",
    "echarts": "^5.6.0",
    "lightweight-charts": "^4.2.3",
    "openapi-fetch": "^0.13.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.4.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
